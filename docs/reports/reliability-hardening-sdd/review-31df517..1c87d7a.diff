+      windowsCreated: 0,
+      groupsRestored: 0,
+    });
+  });
+
+  test('keeps successful saved-tab associations when the middle creation fails', async () => {
+    const session = makeSession([
+      {
+        url: 'https://association.test/first',
+        title: 'A'.repeat(700),
